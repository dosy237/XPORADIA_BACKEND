# ============================================================
# Epsilon Backend — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# NE JAMAIS committer .env dans Git
# ============================================================

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=your-very-long-secret-key-here-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données (PostgreSQL en staging/prod)
DATABASE_URL=sqlite:///db_dev.sqlite3
# DATABASE_URL=postgresql://epsilon_user:password@localhost:5432/epsilon_db

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Paiements — CinetPay
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=

# Paiements — Fedapay (fallback)
FEDAPAY_API_KEY=
FEDAPAY_ENV=sandbox

# Notifications — Firebase Cloud Messaging
FCM_SERVER_KEY=

# SMS — Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1234567890

# Email — SendGrid
SENDGRID_API_KEY=

# Monitoring — Sentry
SENTRY_DSN=

# Storage — AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=epsilon-dev
AWS_CLOUDFRONT_DOMAIN=
